# Shopify API credentials from Dev Dashboard (https://dev.shopify.com/dashboard)
# Navigate to Catalogs > Get an API key to obtain these values
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Optional: saved catalog slug from Shopify Dev Dashboard (Catalogs section)
# When set, all product searches are scoped to this catalog.
# When omitted, Shopify's global catalog (all merchants) is used.
SHOPIFY_CATALOG_ID=

# UCP agent profile URL — must point to a valid UCP profile JSON document
# (per https://ucp.dev/2026-04-08/specification/overview, agent profiles can
# be served at any HTTPS URL, but the document must be a spec-compliant
# UCP profile). For demos we use Shopify's published reference example so
# we don't need to self-host and maintain the profile document.
UCP_AGENT_PROFILE=https://shopify.dev/ucp/agent-profiles/2026-04-08/valid-with-capabilities.json

# Server port (Render sets this automatically; 3000 is used for local dev)
PORT=3000
